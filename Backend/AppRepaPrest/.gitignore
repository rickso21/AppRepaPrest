# =============================================
# .gitignore para Laravel 12
# =============================================

# Archivos del sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Archivos de entorno
.env
.env.backup
.env.production
.env.local
.env.*.local

# Dependencias de PHP
/vendor/
composer.phar
composer.lock

# Dependencias de Node.js
/node_modules/
npm-debug.log
yarn-error.log
yarn.lock
package-lock.json

# Archivos de Laravel específicos
/storage/*.key
/storage/framework/*
/storage/logs/*
/storage/app/public/*
!storage/app/public/.gitkeep
!storage/framework/.gitkeep
!storage/logs/.gitkeep

# Archivos de sesión
/storage/framework/sessions/*
!storage/framework/sessions/.gitkeep

# Cache de Laravel
/bootstrap/cache/*.php
!bootstrap/cache/.gitkeep

# Archivos de log
*.log
storage/logs/*.log

# Archivos de prueba
/testbench.yaml
/phpunit.xml
.phpunit.result.cache

# Herramientas de desarrollo
/.idea/
/.vscode/
*.sublime-*
*.swp
*.swo
*~
.phpstorm.meta.php
._*
.idea/workspace.xml
.idea/tasks.xml
.idea/dataSources.xml
.idea/dataSources.ids
.idea/dictionaries
.idea/shelf
.idea/inspectionProfiles

# Archivos de compilación
public/css/*
public/js/*
public/mix-manifest.json
public/hot
public/storage
public/build/
!public/css/.gitkeep
!public/js/.gitkeep

# Archivos de cache de Composer
/.composer-cache/

# Archivos de cobertura de código
coverage/
coverage.xml
.clover
.php_cs.cache

# Archivos de Docker
.docker/
docker-compose.override.yml

# Archivos temporales
/tmp/
/temp/
*.tmp
*.temp

# Archivos de backup
*.bak
*.old
*.orig

# Archivos de entorno de desarrollo
.env.dev
.env.testing
.env.staging

# Homestead
Homestead.json
Homestead.yaml
Homestead.yaml.example
.homestead/

# Servidor local
/.php-version
/.php_cs
.php_cs.dist
.phpcs.xml
phpcs.xml
.phpunit.result.cache

# Configuración de PHPStorm
/.phpstorm.meta.php

# Archivos de XAMPP específicos
/xampp/
*.pid

# Tus archivos específicos del proyecto
/backup/
/*.sql
/*.dump
/database/*.sql
/database/*.dump

# Archivos de node
.env.npm
.npmrc
.yarnrc

# Archivos de tipos de TypeScript
*.tsbuildinfo

# IDE específicos
/.vscode/
*.code-workspace

# Archivos de cobertura
*.cov
*.lcov

# Archivos de Zip
*.zip
*.rar
*.7z
*.tar.gz

# Archivos de imágenes grandes
*.psd
*.ai
*.eps

# Archivos de configuración local
config/local/
config/*.local.php